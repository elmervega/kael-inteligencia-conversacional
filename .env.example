# Kael Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit actual .env files to git - they are in .gitignore

# ============ DATABASE ============
DATABASE_URL=

# ============ AUTHENTICATION ============
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ============ EXTERNAL APIs ============
CLAUDE_API_KEY=
TELEGRAM_BOT=
OPENAI_API_KEY=
WHATSAPP_API_KEY=

# ============ EMAIL & NOTIFICATIONS ============
EMAIL_USER=
EMAIL_PASSWORD=

# ============ n8n CONFIGURATION ============
N8N_WEBHOOK_SECRET=
N8N_HOST=
N8N_PRODUCTION_URL=

# ============ NODE ENVIRONMENT ============
NODE_ENV=

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=

# ============ LOGGING ============
DEBUG=
LOG_LEVEL=
