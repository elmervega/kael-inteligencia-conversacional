# Kael Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env files to git

# ============ DATABASE ============
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Do NOT expose this in version control
DATABASE_URL=postgresql://kaeluser:your_secure_password@localhost:5432/kael

# ============ AUTHENTICATION ============
# NextAuth Secret - Generate with: openssl rand -base64 32
# Keep this secret and rotate periodically
NEXTAUTH_SECRET=your_generated_secret_here

# NextAuth URL - Where your app is hosted
# For development: http://localhost:3000
# For production: https://kael.quest
NEXTAUTH_URL=http://localhost:3000

# ============ EXTERNAL APIs ============
# Claude API Key from https://console.anthropic.com
# Keep secure - never expose in client-side code
CLAUDE_API_KEY=CLAUDE_API_KEY_PLACEHOLDER

# Telegram Bot Token from @BotFather
# Do not expose to users
TELEGRAM_BOT=your_telegram_bot_token_here

# OpenAI Whisper API Key from https://platform.openai.com
# Used for audio transcription
OPENAI_API_KEY=sk-proj-your_openai_key_here

# WhatsApp Business API credentials (if using)
# Get from https://www.whatsapp.com/business/api
WHATSAPP_API_KEY=your_whatsapp_api_key_here

# ============ EMAIL & NOTIFICATIONS ============
# Email service configuration (Gmail SMTP example)
# For Gmail: Use app-specific password, not your main password
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# ============ n8n CONFIGURATION ============
# n8n webhook secret for securing webhooks
# Generate a random string
N8N_WEBHOOK_SECRET=your_secure_webhook_secret

# n8n local instance URL (development)
N8N_HOST=http://localhost:5678

# n8n public URL (production)
N8N_PRODUCTION_URL=https://n8n.kael.quest

# ============ NODE ENVIRONMENT ============
# Set to 'production' on production servers
NODE_ENV=development

# ============ RATE LIMITING ============
# Rate limit configurations (optional, can use defaults)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=10   # Max requests per window

# ============ LOGGING ============
# Set to 'true' to enable verbose logging
DEBUG=false
LOG_LEVEL=info  # debug, info, warn, error
